{
  "version": 2,
  "installCommand": "corepack pnpm install --frozen-lockfile",
  "buildCommand": "corepack pnpm run build",
  "devCommand": "corepack pnpm run dev",
  "outputDirectory": "dist/public",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/converter",
      "dest": "/index.html"
    },
    {
      "src": "/batch",
      "dest": "/index.html"
    },
    {
      "src": "/documentation",
      "dest": "/index.html"
    },
    {
      "handle": "filesystem"
    }
  ]
}
